---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import site from "../data/site.json";

const articles = (await getCollection("articles", ({ data }) => !data.draft)).sort(
  (x, y) => x.data.order - y.data.order
);

const card = (a: (typeof articles)[number]) => ({
  href: `/${a.id}`,
  image: a.data.cardImage,
  category: a.data.category,
  title: a.data.cardTitle || a.data.title,
  summary: a.data.cardSummary,
});

const cards = articles.map(card);
const picks = articles.slice(0, 4);
const latest = articles.slice(0, 3).map(card);

const heroSlides = site.hero?.slides ?? [];
---
<BaseLayout
  title="Top Gear Decide — Expert Food, Supplement & Drink Reviews"
  description="Independent, hands-on reviews and best-picks guides for supplements, pantry staples and drinks. Find what's actually worth buying — without the guesswork."
  path="/"
>
  <!-- HERO -->
  <section class="hero">
    {heroSlides.length > 0 && (
      <div class="hero-slides" aria-hidden="true">
        {heroSlides.map((s, i) => (
          <img
            src={s.image}
            alt={s.alt || ""}
            class:list={["hero-slide", { active: i === 0 }]}
            loading={i === 0 ? "eager" : "lazy"}
          />
        ))}
      </div>
    )}
    {heroSlides.length > 0 && <div class="hero-overlay"></div>}
    <div class="container hero-content">
      <h1>Smarter food & supplement buys, backed by real research</h1>
      <p>We compare and rank the supplements, pantry staples and drinks worth your money — so you can skip the label-reading and buy with confidence.</p>
      <a href="#best-picks" class="btn">Explore Best Picks</a>
    </div>
    {heroSlides.length > 1 && (
      <script is:inline>
        (function () {
          var imgs = document.querySelectorAll(".hero-slides .hero-slide");
          if (imgs.length < 2) return;
          var i = 0;
          setInterval(function () {
            imgs[i].classList.remove("active");
            i = (i + 1) % imgs.length;
            imgs[i].classList.add("active");
          }, 5000);
        })();
      </script>
    )}
  </section>

  <!-- CARD GRID: latest articles -->
  <section class="section" id="latest">
    <div class="container">
      <div class="section-head">
        <h2>Fresh Off the Test Bench</h2>
        <a href="#best-picks" class="read-more" style="color:var(--orange);font-weight:700;">View all &rarr;</a>
      </div>
      <div class="card-grid">
        {cards.map((c) => (
          <a class="card" href={c.href}>
            <div class="card-thumb">
              {c.image && <img src={c.image} alt={c.title} width="600" height="340" loading="lazy" />}
            </div>
            <div class="card-body">
              <span class="tag" set:html={c.category} />
              <h3>{c.title}</h3>
              <p>{c.summary}</p>
              <span class="read-more">Read review &rarr;</span>
            </div>
          </a>
        ))}

        <a class="card" href={site.deals.link}>
          <div class="card-thumb">
            {site.deals.image && <img src={site.deals.image} alt={site.deals.title} width="600" height="340" loading="lazy" />}
          </div>
          <div class="card-body">
            <span class="tag">Deals</span>
            <h3>{site.deals.title}</h3>
            <p>{site.deals.text}</p>
            <span class="read-more">See deals &rarr;</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- EDITOR'S BEST PICKS -->
  <section class="section section-alt" id="best-picks">
    <div class="container">
      <div class="section-head"><h2>Editor's Best Picks</h2></div>
      <div class="pick-list">
        {picks.map((a, i) => (
          <div class="pick">
            <div class="rank">{i + 1}</div>
            <div>
              <h3>{a.data.quickPick.name} — {a.data.category} Top Pick</h3>
              <p>{a.data.quickPick.reason}</p>
            </div>
            <a href={`/${a.id}`} class="btn">See review</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LATEST REVIEWS + DEALS anchor -->
  <section class="section" id="deals">
    <div class="container">
      <div class="section-head"><h2>Latest Reviews</h2></div>
      <div class="card-grid">
        {latest.map((c) => (
          <a class="card" href={c.href}>
            <div class="card-thumb">
              {c.image && <img src={c.image} alt={c.title} width="600" height="340" loading="lazy" />}
            </div>
            <div class="card-body">
              <span class="tag" set:html={c.category} />
              <h3>{c.title}</h3>
              <p>{c.summary}</p>
              <span class="read-more">Read review &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
